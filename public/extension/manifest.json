{
  "manifest_version": 3,
  "name": "AdSense Policy Shield",
  "version": "1.0.0",
  "description": "Real-time AdSense policy violation detection for your website.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
